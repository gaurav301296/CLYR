# CLYR v2 — Environment Configuration
# Copy this to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8005
ENVIRONMENT=development
DEBUG=true

# OpenRouter (LLM)
OPENAI_API_KEY=sk-or-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openrouter/owl-alpha

# Supabase (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-supabase-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Rate Limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_UPLOAD_RPM=10

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# Upload
MAX_UPLOAD_SIZE_MB=10

# Email (Resend)
RESEND_API_KEY=re_your-key-here
EMAIL_FROM=CLYR <hello@clyr.in>

# Error Monitoring (Sentry)
SENTRY_DSN=
